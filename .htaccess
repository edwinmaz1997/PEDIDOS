# OneSignal Service Worker — acceso sin restricciones
<Files "OneSignalSDKWorker.js">
    Order Allow,Deny
    Allow from all
    Satisfy Any
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Access-Control-Allow-Origin "*"
</Files>

<Files "OneSignalSDK.sw.js">
    Order Allow,Deny
    Allow from all
    Satisfy Any
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Access-Control-Allow-Origin "*"
</Files>

Options -Indexes
RewriteEngine On

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/.*$ api/index.php [QSA,L]

# Slugs de negocios: nuevaexpress.com/{slug} → pedido.html?business=ID
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(cliente|negocio|admin|repartidor|api|assets|database)/
RewriteCond %{REQUEST_URI} !^/(index|404|nosotros|terminos|negocio|restablecer-contrasena|manifest|sw|OneSignal|favicon)
RewriteRule ^([a-zA-Z0-9_-]+)$ /go.php?slug=$1 [QSA,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(cliente|negocio|admin|repartidor)/(.*)$ /$1/$2 [L]

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy strict-origin-when-cross-origin
    Header unset X-Powered-By
    Header unset Server
</IfModule>

<FilesMatch "\.(sql|log|env|bak|php~)$">
    Order allow,deny
    Deny from all
</FilesMatch>
